{
  "name": "weblens",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "WebLens is a Chrome side panel extension for local UI, HTML semantics, and accessibility checks.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "fixtures": "vite fixtures --host 127.0.0.1 --port 4174",
    "test:browser": "playwright test",
    "package": "node scripts/package-extension.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.320",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "yazl": "^3.3.1"
  }
}
